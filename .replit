run = "bash scripts/replit-start.sh"
entrypoint = "server/index.ts"
language = "nodejs"

[env]
PORT = "5000"
BACKEND_PORT = "5001"
PYTHON_PATH = "python3"
NODE_ENV = "development"

# Used when publishing via Replit Deployments: build the client/server
# bundle once, then run the production stack (Express + FastAPI).
[deployment]
build = ["bash", "-c", "npm ci && npm run build && python3 -m venv venv && ./venv/bin/pip install -r requirements.txt"]
run = ["bash", "scripts/replit-deploy.sh"]
deploymentTarget = "vm"

[[ports]]
localPort = 5000
externalPort = 80
